{
    "version": "1.0.0",
    "name": "cerealkiller97/filament-bug-reports",
    "description": "A Filament plugin to collect in-app bug reports and push validated ones to GitHub issues.",
    "keywords": [
        "filament",
        "laravel",
        "bug-reports",
        "github",
        "issues",
        "plugin"
    ],
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "CerealKiller97",
            "homepage": "https://stefanbogdanovic.dev",
            "email": "stefan@stefanbogdanovic.dev",
            "role": "Developer"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.10",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^11.1",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-livewire": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/extension-installer": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "CerealKiller97\\FilamentBugReports\\": "src/",
            "CerealKiller97\\FilamentBugReports\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CerealKiller97\\FilamentBugReports\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint",
        "analyse": "phpstan analyse --memory-limit=2G",
        "type-coverage": "@php -d memory_limit=-1 vendor/bin/pest --type-coverage --min=100"
    },
    "extra": {
        "laravel": {
            "providers": [
                "CerealKiller97\\FilamentBugReports\\BugReportsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    }
}
